{
  "info": {
    "name": "EdgeAuth",
    "description": "GraphQL API for the EdgeAuth stateless edge identity verifier. It verifies EdDSA JWTs and did:key Verifiable Credentials against a trust policy — no database, no session state.\n\nSetup:\n1. Start the server so it also trusts the sample credential's issuer DID:\n   `EA_TRUSTED_ISSUERS={{vcIssuerDid}} cargo run -p edgeauth-node -- serve`\n2. Set the `baseUrl` collection variable (default http://localhost:8080).\n\nThe pre-baked `{{jwt}}` and `{{credential}}` variables are signed by the node's deterministic local key (seed 7) and expire in the year 2100, so they verify out of the box.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "jwt", "value": "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCIsImtpZCI6ImVkZ2VhdXRoLWxvY2FsLTEifQ.eyJpc3MiOiJodHRwczovL2lzc3Vlci5sb2NhbCIsInN1YiI6InVzZXItYWxpY2UiLCJhdWQiOiJlZGdlLWFwaSIsImV4cCI6NDEwMjQ0NDgwMCwibmJmIjowLCJpYXQiOjAsImp0aSI6InBvc3RtYW4tMSIsInNjb3BlIjoib3BlbmlkIHByb2ZpbGUiLCJyb2xlcyI6WyJyZWFkZXIiXX0.VxEh6yz6wx9AebvGCmYbbR_unO78Pdh1NNJP355GURrQWXrZ5nczaVY_qxUmieDwjWokjE_PLe81wnLT7oYNBQ", "type": "string" },
    { "key": "vcIssuerDid", "value": "did:key:z6MkmNL6xksdEJENGk9Z1qqGsY5njKQdjU1UhnUEUvWyQUVX", "type": "string" },
    { "key": "credential", "value": "{\"id\":\"urn:cred:postman-1\",\"type\":\"KycVerified\",\"issuer\":\"did:key:z6MkmNL6xksdEJENGk9Z1qqGsY5njKQdjU1UhnUEUvWyQUVX\",\"subject\":{\"id\":\"did:key:z6MkfDSNRs2i9S6LZ5vd4RbpZ6754H7R3btDqRTeHhamqvuJ\",\"claims\":{\"kyc_level\":\"gold\"}},\"issued_at\":0,\"expires_at\":4102444800,\"proof\":{\"type\":\"Ed25519Signature2020\",\"verification_method\":\"did:key:z6MkmNL6xksdEJENGk9Z1qqGsY5njKQdjU1UhnUEUvWyQUVX\",\"created\":0,\"signature_hex\":\"18be640d37c7781791b1ba2d56bead289f1c7f59ad196c608f98231385c792f84bccc39e9c7bc5e419ea23a0eed164d6dc6464d882d9ceaa7eb66e2c0da83506\"}}", "type": "string" }
  ],
  "item": [
    {
      "name": "Health / Version / Policy / JWKS / Stats",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "{ health apiVersion trustPolicy { trustedIssuers expectedAudience requiredScopes leewaySecs } jwks { keys { kty crv kid } } stats { jwtAccepted jwtRejected vcAccepted vcRejected } }",
            "variables": ""
          }
        }
      }
    },
    {
      "name": "Verify JWT (valid)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const v = pm.response.json().data.verifyJwt;",
              "pm.test('accepted', () => pm.expect(v.valid).to.eql(true));",
              "pm.test('kind is JWT', () => pm.expect(v.kind).to.eql('JWT'));",
              "pm.test('subject resolved', () => pm.expect(v.subject).to.eql('user-alice'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Verify($t: String!) { verifyJwt(token: $t) { valid kind subject issuer scopes roles reason checks { signature notExpired notBefore issuerTrusted audience scopes notRevoked } } }",
            "variables": "{\n  \"t\": \"{{jwt}}\"\n}"
          }
        }
      }
    },
    {
      "name": "Verify JWT (tightened audience — still valid)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const v = pm.response.json().data.verifyJwt;",
              "pm.test('accepted with matching audience', () => pm.expect(v.valid).to.eql(true));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Verify($t: String!) { verifyJwt(token: $t, audience: \"edge-api\") { valid checks { audience } } }",
            "variables": "{\n  \"t\": \"{{jwt}}\"\n}"
          }
        }
      }
    },
    {
      "name": "Verify JWT (wrong audience override — rejected)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const v = pm.response.json().data.verifyJwt;",
              "pm.test('rejected on audience', () => pm.expect(v.valid).to.eql(false));",
              "pm.test('audience check failed', () => pm.expect(v.checks.audience).to.eql(false));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Verify($t: String!) { verifyJwt(token: $t, audience: \"other-api\") { valid reason checks { audience } } }",
            "variables": "{\n  \"t\": \"{{jwt}}\"\n}"
          }
        }
      }
    },
    {
      "name": "Verify JWT (require missing scope — rejected)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation Verify($t: String!) { verifyJwt(token: $t, requiredScopes: [\"admin\"]) { valid reason checks { scopes } } }",
            "variables": "{\n  \"t\": \"{{jwt}}\"\n}"
          }
        }
      }
    },
    {
      "name": "Verify Credential (valid — needs EA_TRUSTED_ISSUERS)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// The GraphQL `credential` argument is a String, so JSON-encode the",
              "// raw credential into an escaped, quoted string literal.",
              "const raw = pm.collectionVariables.get('credential');",
              "pm.variables.set('credentialEscaped', JSON.stringify(raw));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const v = pm.response.json().data.verifyCredential;",
              "pm.test('kind is VERIFIABLE_CREDENTIAL', () => pm.expect(v.kind).to.eql('VERIFIABLE_CREDENTIAL'));",
              "// Accepted only when the server was started with EA_TRUSTED_ISSUERS={{vcIssuerDid}}.",
              "pm.test('signature is valid', () => pm.expect(v.checks.signature).to.eql(true));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation VerifyVc($c: String!) { verifyCredential(credential: $c) { valid kind subject issuer reason checks { signature notExpired issuerTrusted notRevoked } } }",
            "variables": "{\n  \"c\": {{credentialEscaped}}\n}"
          }
        }
      }
    },
    {
      "name": "Refresh JWKS",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/graphql", "host": ["{{baseUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "mutation { refreshJwks }",
            "variables": ""
          }
        }
      }
    }
  ]
}
