# EdgeAuth node configuration (copy to `.env`; all values are optional).

# Bind address for the GraphQL server.
EA_BIND_ADDR=0.0.0.0:8080

# Max verification mutations per second before requests are rejected.
EA_RATE_LIMIT_RPS=100

# Deterministic seed (0-255) for the built-in local signing key. The node
# trusts the matching public key as its JWKS.
EA_SIGNER_SEED=7

# Trusted JWT issuer (`iss`).
EA_ISSUER=https://issuer.local

# Extra trusted issuers or credential-issuer DIDs (comma-separated).
# EA_TRUSTED_ISSUERS=did:key:z6Mk...

# Expected audience (`aud`). Leave unset to disable the audience check.
# EA_AUDIENCE=edge-api

# Permitted clock skew, in seconds.
EA_LEEWAY_SECS=60

# Optional remote JWKS endpoint. When set, keys are refreshed from here.
# EA_JWKS_URL=https://issuer.example/.well-known/jwks.json
# EA_JWKS_REFRESH_SECS=300

# Log level.
RUST_LOG=info
